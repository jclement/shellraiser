# .shellraiser.toml — checked-in project config (safe to commit).
# Override locally with .shellraiser.local.toml (gitignore it); env vars win over both.
# Precedence (highest first): env  →  .shellraiser.local.toml  →  .shellraiser.toml  →  defaults

# id            = "barreleye"    # box identity → sr_<id> container + sr_<id>_vol volume + tailnet name
# addr          = ":7000"        # listen address
# name          = "my-project"   # header repo name (else derived from git remote)
# worktrees_dir = ""             # default: $SHELLRAISER_WORKTREES or <repo>/.worktrees
# postgres      = true           # run postgres + pgweb (/db)
# code          = true           # run code-server (/edit, per-worktree VS Code)
# no_auth       = false          # disable auth entirely (trusted local only)

# First-class run/teardown for the project:
# run      = ["npm", "run", "dev"]     # the header Run button
# teardown = ["docker", "compose", "down"]   # runs when the workspace stops

# Named container→host port mappings, forwarded on start (no ranges). `to`
# defaults to `from`; a runtime change to the host port is stored and wins, so
# conflicts resolve without editing this file. (HTTP also works via /p/<port>/.)
# [[ports]]
#   name = "web"
#   from = 5173      # container port
#   to   = 5173      # host port (optional; defaults to `from`)
# [[ports]]
#   name = "api"
#   from = 8080
#   to   = 18080

# Override the built-in launcher commands (argv arrays):
# claude = ["claude", "--dangerously-skip-permissions"]
# codex  = ["codex", "--dangerously-bypass-approvals-and-sandbox"]
# editor = ["hx"]
# shell  = ["zsh"]

# Custom launchers — appear as extra buttons in the toolbar. These can ONLY be
# defined in .shellraiser files (not env). Each runs in the selected worktree.
[[commands]]
name = "dev"
icon = "▶"
args = ["mise", "run", "dev"]

[[commands]]
name = "test"
icon = "✓"
args = ["mise", "run", "test"]

[[commands]]
name = "psql"
icon = "⛁"
args = ["psql", "postgres://postgres:postgres@127.0.0.1:5432/postgres"]
