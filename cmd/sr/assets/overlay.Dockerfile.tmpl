# shellraiser lean overlay — rendered by `sr` on top of {{.Base}} (the shellraiser base
# by default, or a project's own base/dockerfile image). It injects only the
# irreducible must-haves and the worker binary (COPYed LAST so a worker bump
# rebuilds only this tiny final layer).
FROM {{.Base}}
{{if .Lean}}
# Custom base — add the must-haves the coordinator depends on. Debian/Ubuntu only.
# DEBIAN_FRONTEND=noninteractive so openssh-server's postinst can't block on debconf.
RUN DEBIAN_FRONTEND=noninteractive apt-get update \
    && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        ca-certificates curl git openssh-server gosu sudo \
    && rm -rf /var/lib/apt/lists/* \
    && (id -u ubuntu >/dev/null 2>&1 || useradd -m -s /bin/bash ubuntu) \
    && echo 'ubuntu ALL=(ALL) NOPASSWD:ALL' > /etc/sudoers.d/ubuntu \
    && git config --system --add safe.directory '*'
{{end}}
ENV SHELLRAISER_REPO=/work \
    SHELLRAISER_WORKTREES=/home/ubuntu/worktrees \
    PGDATA=/home/ubuntu/.local/share/shellraiser/postgres
COPY entrypoint.sh /usr/local/bin/shellraiser-entrypoint
COPY worker /usr/local/bin/shellraiser
RUN chmod +x /usr/local/bin/shellraiser-entrypoint /usr/local/bin/shellraiser
WORKDIR /work
EXPOSE 7000
ENTRYPOINT ["shellraiser-entrypoint"]
